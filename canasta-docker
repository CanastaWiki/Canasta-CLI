#!/usr/bin/env bash
#
# canasta-docker - Run Canasta-Ansible from a Docker container.
#
# Only Docker is required on the host. No Python, no Ansible.
#
# Install:
#   curl -o /usr/local/bin/canasta \
#     https://raw.githubusercontent.com/CanastaWiki/Canasta-Ansible/main/canasta-docker
#   chmod +x /usr/local/bin/canasta
#
# Usage is identical to the native install:
#   canasta create -i mysite -w main
#   canasta list
#   canasta --host prod1 start -i mysite

set -euo pipefail

IMAGE="${CANASTA_ANSIBLE_IMAGE:-ghcr.io/canastawiki/canasta-ansible:latest}"

# Determine config directory (same logic as canasta_registry.py)
if [[ -n "${CANASTA_CONFIG_DIR:-}" ]]; then
    CONFIG_DIR="$CANASTA_CONFIG_DIR"
elif [[ "$(id -u)" == "0" ]]; then
    CONFIG_DIR="/etc/canasta"
elif [[ "$(uname)" == "Darwin" ]]; then
    CONFIG_DIR="$HOME/Library/Application Support/canasta"
else
    CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/canasta"
fi

# Ensure config directory exists
mkdir -p "$CONFIG_DIR"

# Base mounts: Docker socket + registry + current directory
if [[ "${DOCKER_HOST:-}" == unix://* ]]; then
    DOCKER_SOCK_PATH="${DOCKER_HOST#unix://}"
else
    DOCKER_SOCK_PATH="/var/run/docker.sock"
fi
MOUNTS=(
    -v "$DOCKER_SOCK_PATH:/var/run/docker.sock"
    -v "$CONFIG_DIR":"$CONFIG_DIR"
    -e "CANASTA_CONFIG_DIR=$CONFIG_DIR"
    -v "$(pwd)":"$(pwd)"
    -w "$(pwd)"
)

# Parse args to find instance path from --id/-i (look up in conf.json)
# so we can mount it if it's outside the current directory.
CONF_FILE="$CONFIG_DIR/conf.json"
INSTANCE_PATH=""

if [[ -f "$CONF_FILE" ]]; then
    # Extract --id or -i value from args
    INST_ID=""
    ARGS=("$@")
    for ((i=0; i<${#ARGS[@]}; i++)); do
        case "${ARGS[$i]}" in
            --id|-i)
                if [[ $((i+1)) -lt ${#ARGS[@]} ]]; then
                    INST_ID="${ARGS[$((i+1))]}"
                fi
                ;;
            --id=*)
                INST_ID="${ARGS[$i]#--id=}"
                ;;
        esac
    done

    # Look up instance path from conf.json
    if [[ -n "$INST_ID" ]] && command -v python3 &>/dev/null; then
        INSTANCE_PATH=$(python3 -c "
import json, sys
try:
    with open('$CONF_FILE') as f:
        data = json.load(f)
    instances = data.get('Instances', {})
    inst = instances.get('$INST_ID', {})
    print(inst.get('path', ''))
except:
    pass
" 2>/dev/null || true)
    elif [[ -n "$INST_ID" ]]; then
        # Fallback: grep for the path (no python3 available)
        INSTANCE_PATH=$(grep -A5 "\"$INST_ID\"" "$CONF_FILE" 2>/dev/null \
            | grep '"path"' | head -1 \
            | sed 's/.*"path"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/' \
            || true)
    fi
fi

# Mount all instance paths from conf.json (needed for list, upgrade,
# and any command that reads instance directories).
if [[ -f "$CONF_FILE" ]]; then
    if command -v python3 &>/dev/null; then
        ALL_PATHS=$(python3 -c "
import json
try:
    with open('$CONF_FILE') as f:
        data = json.load(f)
    for inst in data.get('Instances', {}).values():
        p = inst.get('path', '')
        if p:
            print(p)
except:
    pass
" 2>/dev/null || true)
    else
        ALL_PATHS=$(grep '"path"' "$CONF_FILE" 2>/dev/null \
            | sed 's/.*"path"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/' \
            || true)
    fi

    CWD="$(pwd)"
    while IFS= read -r ipath; do
        [[ -z "$ipath" ]] && continue
        case "$ipath" in
            "$CWD"*) ;; # Already covered by cwd mount
            *)
                # Skip if this is the active instance (will be mounted rw below)
                if [[ "$ipath" != "$INSTANCE_PATH" ]]; then
                    MOUNTS+=(-v "$ipath":"$ipath":ro)
                fi
                ;;
        esac
    done <<< "$ALL_PATHS"
fi

# Mount specific instance path read-write if --id provided
if [[ -n "$INSTANCE_PATH" ]]; then
    CWD="$(pwd)"
    case "$INSTANCE_PATH" in
        "$CWD"*) ;; # Already covered by cwd mount
        *)
            # Override the ro mount with rw for the active instance
            MOUNTS+=(-v "$INSTANCE_PATH":"$INSTANCE_PATH")
            ;;
    esac
fi

# Parse -p/--path and -d/--database from args to mount directories
ARGS=("$@")
for ((i=0; i<${#ARGS[@]}; i++)); do
    case "${ARGS[$i]}" in
        --path|-p)
            if [[ $((i+1)) -lt ${#ARGS[@]} ]]; then
                CREATE_PATH="${ARGS[$((i+1))]}"
                CWD="$(pwd)"
                case "$CREATE_PATH" in
                    "$CWD"/*|"$CWD") ;; # Already covered
                    *)
                        MOUNTS+=(-v "$CREATE_PATH":"$CREATE_PATH")
                        ;;
                esac
            fi
            ;;
        --database|-d)
            if [[ $((i+1)) -lt ${#ARGS[@]} ]]; then
                DB_FILE="${ARGS[$((i+1))]}"
                DB_DIR="$(dirname "$DB_FILE")"
                CWD="$(pwd)"
                case "$DB_DIR" in
                    "$CWD"/*|"$CWD") ;; # Already covered
                    *)
                        MOUNTS+=(-v "$DB_DIR":"$DB_DIR":ro)
                        ;;
                esac
            fi
            ;;
    esac
done

# Mount SSH keys for remote host access
if [[ -d "$HOME/.ssh" ]]; then
    MOUNTS+=(-v "$HOME/.ssh":"$HOME/.ssh":ro)
fi

# When the user runs 'canasta upgrade', pull the latest image and update
# this wrapper script from the main branch, matching the Go CLI's
# self-update behavior.
WRAPPER_PATH="$(readlink -f "${BASH_SOURCE[0]}" 2>/dev/null || echo "${BASH_SOURCE[0]}")"
WRAPPER_URL="https://raw.githubusercontent.com/CanastaWiki/Canasta-Ansible/main/canasta-docker"
for arg in "$@"; do
    case "$arg" in
        -*) continue ;;
        upgrade)
            echo "Pulling latest canasta-ansible image..."
            docker pull "$IMAGE"

            # Update the wrapper script itself if the upstream differs.
            if command -v curl &>/dev/null; then
                TMP_WRAPPER="$(mktemp)"
                if curl -fsSL "$WRAPPER_URL" -o "$TMP_WRAPPER"; then
                    if ! cmp -s "$TMP_WRAPPER" "$WRAPPER_PATH"; then
                        echo "Updating canasta wrapper script..."
                        if [[ -w "$WRAPPER_PATH" ]]; then
                            cat "$TMP_WRAPPER" > "$WRAPPER_PATH"
                            chmod +x "$WRAPPER_PATH"
                            echo "Wrapper updated. Run 'canasta upgrade' again to finish upgrading instances."
                            rm -f "$TMP_WRAPPER"
                            exit 0
                        elif command -v sudo &>/dev/null; then
                            if sudo cp "$TMP_WRAPPER" "$WRAPPER_PATH" && sudo chmod +x "$WRAPPER_PATH"; then
                                echo "Wrapper updated. Run 'canasta upgrade' again to finish upgrading instances."
                                rm -f "$TMP_WRAPPER"
                                exit 0
                            else
                                echo "Warning: failed to update wrapper at $WRAPPER_PATH" >&2
                            fi
                        else
                            echo "Warning: cannot write to $WRAPPER_PATH (no sudo available)" >&2
                        fi
                    fi
                    rm -f "$TMP_WRAPPER"
                fi
            fi
            break
            ;;
        *) break ;;
    esac
done

# When running 'canasta create' without -p/--path, inject -p with the
# host cwd so the instance directory lands on a host-visible path.
# Without this, the default path "." is resolved inside the container
# against /opt/canasta-ansible, which the host Docker daemon can't mount.
EXTRA_ARGS=()
HAS_CREATE=false
HAS_PATH=false
for arg in "$@"; do
    case "$arg" in
        create) HAS_CREATE=true ;;
        -p|--path|-p=*|--path=*) HAS_PATH=true ;;
    esac
done
if [[ "$HAS_CREATE" == "true" ]] && [[ "$HAS_PATH" == "false" ]]; then
    EXTRA_ARGS=(-p "$(pwd)")
fi

exec docker run --rm -i \
    "${MOUNTS[@]}" \
    "$IMAGE" "$@" "${EXTRA_ARGS[@]}"
