#!/usr/bin/env bash
#
# canasta-docker - Run Canasta-Ansible from a Docker container.
#
# Only Docker is required on the host. No Python, no Ansible.
#
# Install:
#   curl -o /usr/local/bin/canasta \
#     https://raw.githubusercontent.com/CanastaWiki/Canasta-Ansible/main/canasta-docker
#   chmod +x /usr/local/bin/canasta
#
# Usage is identical to the native install:
#   canasta create -i mysite -w main
#   canasta list
#   canasta --host prod1 start -i mysite

set -euo pipefail

IMAGE="${CANASTA_ANSIBLE_IMAGE:-ghcr.io/canastawiki/canasta-ansible:latest}"

# Determine config directory (same logic as canasta_registry.py)
if [[ -n "${CANASTA_CONFIG_DIR:-}" ]]; then
    CONFIG_DIR="$CANASTA_CONFIG_DIR"
elif [[ "$(id -u)" == "0" ]]; then
    CONFIG_DIR="/etc/canasta"
elif [[ "$(uname)" == "Darwin" ]]; then
    CONFIG_DIR="$HOME/Library/Application Support/canasta"
else
    CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/canasta"
fi

# Ensure config directory exists
mkdir -p "$CONFIG_DIR"

# Base mounts: Docker socket + registry + current directory + $HOME.
# The container runs as the invoking user's UID/GID so that any files
# written to mounted paths end up owned by the host user, not root.
if [[ "${DOCKER_HOST:-}" == unix://* ]]; then
    DOCKER_SOCK_PATH="${DOCKER_HOST#unix://}"
else
    DOCKER_SOCK_PATH="/var/run/docker.sock"
fi

# Detect the docker socket's GID so the container user can access it.
#
# On Linux, the host stat is reliable. On macOS Docker Desktop, the
# host-side symlink reports a different GID (e.g. 1/daemon) than the
# socket actually has inside Docker Desktop's Linux VM (typically 0/root),
# so we also probe the socket from inside a throwaway container of the
# canasta-ansible image when it's already pulled.
DOCKER_SOCK_GID=""
if [[ -S "$DOCKER_SOCK_PATH" ]]; then
    if docker image inspect "$IMAGE" >/dev/null 2>&1; then
        DOCKER_SOCK_GID="$(docker run --rm \
            -v "$DOCKER_SOCK_PATH:/var/run/docker.sock" \
            --entrypoint stat "$IMAGE" -c '%g' /var/run/docker.sock 2>/dev/null || true)"
    fi
    if [[ -z "$DOCKER_SOCK_GID" ]]; then
        if stat -c '%g' "$DOCKER_SOCK_PATH" >/dev/null 2>&1; then
            DOCKER_SOCK_GID="$(stat -c '%g' "$DOCKER_SOCK_PATH")"
        else
            DOCKER_SOCK_GID="$(stat -f '%g' "$DOCKER_SOCK_PATH")"
        fi
    fi
fi

MOUNTS=(
    -v "$DOCKER_SOCK_PATH:/var/run/docker.sock"
    # Force the in-container docker CLI to use the mounted socket. The
    # host's $HOME (mounted below) brings $HOME/.docker/config.json with
    # it; on macOS Docker Desktop that file selects the "desktop-linux"
    # context, which points docker at a Mac-only socket path that does
    # not exist inside the container. Setting DOCKER_HOST overrides any
    # context selection and forces the canonical path.
    -e "DOCKER_HOST=unix:///var/run/docker.sock"
    -v "$CONFIG_DIR":"$CONFIG_DIR"
    -e "CANASTA_CONFIG_DIR=$CONFIG_DIR"
    -v "$HOME":"$HOME"
    -e "HOME=$HOME"
    -v "$(pwd)":"$(pwd)"
    -w "$(pwd)"
    --user "$(id -u):$(id -g)"
)

# Ensure the container has a passwd entry for the host UID so that
# SSH and Ansible can resolve the current user (required for remote
# host connections via -H).
CANASTA_PASSWD="$CONFIG_DIR/.canasta-passwd"
PASSWD_STALE=false
if [[ ! -f "$CANASTA_PASSWD" ]]; then
    PASSWD_STALE=true
else
    # Regenerate if the image changed (after upgrade) or UID changed.
    PASSWD_IMAGE_ID=$(docker inspect --format '{{.Id}}' "$IMAGE" 2>/dev/null || true)
    if [[ -n "$PASSWD_IMAGE_ID" ]] && ! grep -q "# $PASSWD_IMAGE_ID" "$CANASTA_PASSWD" 2>/dev/null; then
        PASSWD_STALE=true
    fi
fi
if [[ "$PASSWD_STALE" == "true" ]]; then
    docker run --rm --entrypoint cat "$IMAGE" /etc/passwd > "$CANASTA_PASSWD" 2>/dev/null || true
    PASSWD_IMAGE_ID=$(docker inspect --format '{{.Id}}' "$IMAGE" 2>/dev/null || true)
    echo "# $PASSWD_IMAGE_ID" >> "$CANASTA_PASSWD"
fi
if ! grep -q "^[^:]*:[^:]*:$(id -u):" "$CANASTA_PASSWD" 2>/dev/null; then
    echo "canasta:x:$(id -u):$(id -g):canasta:$HOME:/bin/sh" >> "$CANASTA_PASSWD"
fi
MOUNTS+=(-v "$CANASTA_PASSWD:/etc/passwd:ro")
# Add the docker socket GID and all of the host user's supplementary
# groups so the container process has the same group memberships as the
# host user (e.g., www-data for writing to container-owned files).
if [[ -n "$DOCKER_SOCK_GID" ]]; then
    MOUNTS+=(--group-add "$DOCKER_SOCK_GID")
fi
for gid in $(id -G); do
    [[ "$gid" == "$(id -g)" ]] && continue  # skip primary (already set)
    [[ "$gid" == "$DOCKER_SOCK_GID" ]] && continue  # skip if already added
    MOUNTS+=(--group-add "$gid")
done

# Parse args to find instance path from --id/-i (look up in conf.json)
# so we can mount it if it's outside the current directory.
CONF_FILE="$CONFIG_DIR/conf.json"
INSTANCE_PATH=""

if [[ -f "$CONF_FILE" ]]; then
    # Extract --id or -i value from args
    INST_ID=""
    ARGS=("$@")
    for ((i=0; i<${#ARGS[@]}; i++)); do
        case "${ARGS[$i]}" in
            --id|-i)
                if [[ $((i+1)) -lt ${#ARGS[@]} ]]; then
                    INST_ID="${ARGS[$((i+1))]}"
                fi
                ;;
            --id=*)
                INST_ID="${ARGS[$i]#--id=}"
                ;;
        esac
    done

    # Look up instance path from conf.json
    if [[ -n "$INST_ID" ]] && command -v python3 &>/dev/null; then
        INSTANCE_PATH=$(python3 -c "
import json, sys
try:
    with open('$CONF_FILE') as f:
        data = json.load(f)
    instances = data.get('Instances', {})
    inst = instances.get('$INST_ID', {})
    print(inst.get('path', ''))
except:
    pass
" 2>/dev/null || true)
    elif [[ -n "$INST_ID" ]]; then
        # Fallback: grep for the path (no python3 available)
        INSTANCE_PATH=$(grep -A5 "\"$INST_ID\"" "$CONF_FILE" 2>/dev/null \
            | grep '"path"' | head -1 \
            | sed 's/.*"path"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/' \
            || true)
    fi
fi

# Mount all instance paths from conf.json (needed for list, upgrade,
# and any command that reads instance directories).
if [[ -f "$CONF_FILE" ]]; then
    if command -v python3 &>/dev/null; then
        ALL_PATHS=$(python3 -c "
import json
try:
    with open('$CONF_FILE') as f:
        data = json.load(f)
    for inst in data.get('Instances', {}).values():
        p = inst.get('path', '')
        if p:
            print(p)
except:
    pass
" 2>/dev/null || true)
    else
        ALL_PATHS=$(grep '"path"' "$CONF_FILE" 2>/dev/null \
            | sed 's/.*"path"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/' \
            || true)
    fi

    CWD="$(pwd)"
    while IFS= read -r ipath; do
        [[ -z "$ipath" ]] && continue
        # Skip paths that don't exist locally (e.g., remote instances)
        [[ ! -d "$ipath" ]] && continue
        case "$ipath" in
            "$CWD"*|"$HOME"*) ;; # Already covered by cwd or $HOME mount
            *)
                # Skip if this is the active instance (will be mounted rw below)
                if [[ "$ipath" != "$INSTANCE_PATH" ]]; then
                    MOUNTS+=(-v "$ipath":"$ipath":ro)
                fi
                ;;
        esac
    done <<< "$ALL_PATHS"
fi

# Mount specific instance path read-write if --id provided
# Skip if path doesn't exist locally (remote instance).
if [[ -n "$INSTANCE_PATH" ]] && [[ -d "$INSTANCE_PATH" ]]; then
    CWD="$(pwd)"
    case "$INSTANCE_PATH" in
        "$CWD"*) ;; # Already covered by cwd mount
        *)
            # Override the ro mount with rw for the active instance
            MOUNTS+=(-v "$INSTANCE_PATH":"$INSTANCE_PATH")
            ;;
    esac
fi

# Resolve a path to absolute form. Works whether the path exists or not.
# Uses python3 which is a standard dependency of Ansible anyway.
to_abs_path() {
    python3 -c "import os, sys; print(os.path.abspath(sys.argv[1]))" "$1"
}

# Parse -p/--path and -d/--database from args to mount directories.
# Relative paths are resolved to absolute form and the argument list
# is rewritten in place so the container receives absolute paths
# (Docker bind-mount destinations must be absolute).
ARGS=("$@")
NEW_ARGS=()
i=0
while [[ $i -lt ${#ARGS[@]} ]]; do
    arg="${ARGS[$i]}"
    case "$arg" in
        --path|-p)
            if [[ $((i+1)) -lt ${#ARGS[@]} ]]; then
                CREATE_PATH_ABS="$(to_abs_path "${ARGS[$((i+1))]}")"
                NEW_ARGS+=("$arg" "$CREATE_PATH_ABS")
                CWD="$(pwd)"
                case "$CREATE_PATH_ABS" in
                    "$CWD"/*|"$CWD") ;; # Already covered
                    *)
                        MOUNTS+=(-v "$CREATE_PATH_ABS":"$CREATE_PATH_ABS")
                        ;;
                esac
                i=$((i+2))
                continue
            fi
            ;;
        --database|-d)
            if [[ $((i+1)) -lt ${#ARGS[@]} ]]; then
                DB_FILE_ABS="$(to_abs_path "${ARGS[$((i+1))]}")"
                NEW_ARGS+=("$arg" "$DB_FILE_ABS")
                DB_DIR="$(dirname -- "$DB_FILE_ABS")"
                CWD="$(pwd)"
                case "$DB_DIR" in
                    "$CWD"/*|"$CWD") ;; # Already covered
                    *)
                        MOUNTS+=(-v "$DB_DIR":"$DB_DIR":ro)
                        ;;
                esac
                i=$((i+2))
                continue
            fi
            ;;
        --build-from)
            if [[ $((i+1)) -lt ${#ARGS[@]} ]]; then
                BUILD_FROM_ABS="$(to_abs_path "${ARGS[$((i+1))]}")"
                NEW_ARGS+=("$arg" "$BUILD_FROM_ABS")
                CWD="$(pwd)"
                case "$BUILD_FROM_ABS" in
                    "$CWD"/*|"$CWD") ;; # Already covered
                    *)
                        MOUNTS+=(-v "$BUILD_FROM_ABS":"$BUILD_FROM_ABS":ro)
                        ;;
                esac
                i=$((i+2))
                continue
            fi
            ;;
    esac
    NEW_ARGS+=("$arg")
    i=$((i+1))
done
set -- ${NEW_ARGS[@]+"${NEW_ARGS[@]}"}

# SSH keys are already accessible via the $HOME mount (ssh looks in
# $HOME/.ssh by default, and we set HOME to the host user's home).
# Forward SSH agent if available (so passphrase-protected keys work
# without prompting inside the container).
#
# On macOS, the OS launchd manages the SSH agent socket under
# /private/tmp/com.apple.launchd.*/Listeners, which Docker Desktop's
# virtiofs file sharing does not expose by default — bind-mounting
# that path causes the container to fail to start with
# "mountpoint ... is outside of rootfs". Detect that case and skip
# the agent forward; the user can fall back to unencrypted keys or
# point SSH_AUTH_SOCK at a path under $HOME / inside Docker Desktop's
# shared paths.
SSH_FWD_OK=false
if [[ -n "${SSH_AUTH_SOCK:-}" && -S "$SSH_AUTH_SOCK" ]]; then
    SSH_FWD_OK=true
    case "$SSH_AUTH_SOCK" in
        /private/tmp/com.apple.launchd.*|/var/folders/*)
            SSH_FWD_OK=false
            echo "canasta-docker: SSH_AUTH_SOCK is at a path Docker Desktop" \
                "cannot share ($SSH_AUTH_SOCK); skipping SSH agent forward." \
                "Passphrase-protected SSH keys will prompt inside the" \
                "container. To enable agent forwarding, point" \
                "SSH_AUTH_SOCK at a socket under \$HOME." >&2
            ;;
    esac
fi
if [[ "$SSH_FWD_OK" == "true" ]]; then
    MOUNTS+=(
        -v "$SSH_AUTH_SOCK:/tmp/ssh-agent.sock"
        -e "SSH_AUTH_SOCK=/tmp/ssh-agent.sock"
    )
fi

# When the user runs 'canasta upgrade', pull the latest image and update
# this wrapper script from the main branch, matching the Go CLI's
# self-update behavior.
WRAPPER_PATH="$(readlink -f "${BASH_SOURCE[0]}" 2>/dev/null || echo "${BASH_SOURCE[0]}")"
WRAPPER_URL="https://raw.githubusercontent.com/CanastaWiki/Canasta-Ansible/main/canasta-docker"
for arg in "$@"; do
    case "$arg" in
        -*) continue ;;
        upgrade)
            echo "Pulling latest canasta-ansible image..."
            docker pull "$IMAGE"

            # Update the wrapper script itself if the upstream differs.
            if command -v curl &>/dev/null; then
                TMP_WRAPPER="$(mktemp)"
                if curl -fsSL "$WRAPPER_URL" -o "$TMP_WRAPPER"; then
                    if ! cmp -s "$TMP_WRAPPER" "$WRAPPER_PATH"; then
                        echo "Updating canasta wrapper script..."
                        if [[ -w "$WRAPPER_PATH" ]]; then
                            cat "$TMP_WRAPPER" > "$WRAPPER_PATH"
                            chmod +x "$WRAPPER_PATH"
                            echo "Wrapper updated. Run 'canasta upgrade' again to finish upgrading instances."
                            rm -f "$TMP_WRAPPER"
                            exit 0
                        elif command -v sudo &>/dev/null; then
                            if sudo cp "$TMP_WRAPPER" "$WRAPPER_PATH" && sudo chmod +x "$WRAPPER_PATH"; then
                                echo "Wrapper updated. Run 'canasta upgrade' again to finish upgrading instances."
                                rm -f "$TMP_WRAPPER"
                                exit 0
                            else
                                echo "Warning: failed to update wrapper at $WRAPPER_PATH" >&2
                            fi
                        else
                            echo "Warning: cannot write to $WRAPPER_PATH (no sudo available)" >&2
                        fi
                    fi
                    rm -f "$TMP_WRAPPER"
                fi
            fi
            break
            ;;
        *) break ;;
    esac
done

# When running 'canasta create' without -p/--path, inject -p with the
# host cwd so the instance directory lands on a host-visible path.
# Without this, the default path "." is resolved inside the container
# against /opt/canasta-ansible, which the host Docker daemon can't mount.
EXTRA_ARGS=()
HAS_CREATE=false
HAS_PATH=false
HAS_HOST=false
for arg in "$@"; do
    case "$arg" in
        create) HAS_CREATE=true ;;
        -p|--path|-p=*|--path=*) HAS_PATH=true ;;
        -H|--host|-H=*|--host=*) HAS_HOST=true ;;
    esac
done
# Inject -p with the local CWD for local creates (without -p).
# Skip for remote creates (-H) — the remote host resolves its own default.
if [[ "$HAS_CREATE" == "true" ]] && [[ "$HAS_PATH" == "false" ]] && [[ "$HAS_HOST" == "false" ]]; then
    EXTRA_ARGS=(-p "$(pwd)")
fi

# Allocate a TTY when stdin is a terminal (needed for interactive exec).
DOCKER_RUN_FLAGS=(-i)
if [[ -t 0 ]]; then
    DOCKER_RUN_FLAGS+=(-t)
fi

exec docker run --rm "${DOCKER_RUN_FLAGS[@]}" \
    "${MOUNTS[@]}" \
    "$IMAGE" "$@" ${EXTRA_ARGS[@]+"${EXTRA_ARGS[@]}"}
