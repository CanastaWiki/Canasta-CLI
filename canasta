#!/usr/bin/env bash
#
# canasta - CLI wrapper for Canasta-Ansible
#
# Translates CLI-style invocations into ansible-playbook extra-vars.
#
# Usage:
#   ./canasta [--verbose] COMMAND [SUBCOMMAND] [flags...] [-- positional args...]
#
# Examples:
#   ./canasta create --id mysite --wiki mywiki --domain-name example.com
#   ./canasta backup create --id mysite --tag before-upgrade
#   ./canasta config set --id mysite MW_SITE_SERVER=https://example.com
#   ./canasta extension enable --id mysite -- VisualEditor,Cite
#   ./canasta maintenance exec --id mysite -- ls /var/www/mediawiki
#   ./canasta --help
#   ./canasta create --help

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Use the venv's ansible-playbook if available, otherwise fall back to PATH
if [[ -x "${SCRIPT_DIR}/.venv/bin/ansible-playbook" ]]; then
    ANSIBLE_PLAYBOOK="${SCRIPT_DIR}/.venv/bin/ansible-playbook"
else
    ANSIBLE_PLAYBOOK="$(command -v ansible-playbook 2>/dev/null || true)"
    if [[ -z "$ANSIBLE_PLAYBOOK" ]]; then
        echo "Error: ansible-playbook not found. Install Ansible or run: python3 -m venv .venv && .venv/bin/pip install -r requirements.txt" >&2
        exit 1
    fi
fi

# --- Help text ---------------------------------------------------------------

show_help() {
    cat <<'EOF'
Usage: canasta [--verbose] COMMAND [SUBCOMMAND] [flags...] [-- args...]

Canasta MediaWiki management tool (Ansible edition).

Commands:
  create              Create a new Canasta instance
  delete              Delete a Canasta instance
  start               Start a Canasta instance
  stop                Stop a Canasta instance
  restart             Restart a Canasta instance
  list                List all registered instances
  version             Display version information
  upgrade             Upgrade Canasta instances
  add                 Add a wiki to an instance
  remove              Remove a wiki from an instance
  import              Import a database into a wiki
  export              Export a wiki's database
  config get|set|unset  Manage instance configuration
  extension list|enable|disable  Manage MediaWiki extensions
  skin list|enable|disable       Manage MediaWiki skins
  maintenance update|script|extension|exec  Run maintenance operations
  devmode enable|disable         Manage development mode
  sitemap generate|remove        Manage XML sitemaps
  backup init|list|create|restore|delete|unlock|files|check|diff|purge
                      Backup and restore operations
  backup schedule set|list|remove  Manage backup schedules
  gitops init|join|add|rm|push|pull|status|diff|fix-submodules
                      Git-based configuration management

Global flags:
  --verbose, -v       Enable verbose output
  --help, -h          Show this help message

Run 'canasta COMMAND --help' for command-specific help.
EOF
}

show_command_help() {
    local cmd="$1"
    local py="${SCRIPT_DIR}/.venv/bin/python"
    [[ -x "$py" ]] || py="python3"
    "$py" "${SCRIPT_DIR}/scripts/generate_docs.py" \
        "${SCRIPT_DIR}/meta/command_definitions.yml" \
        --command "${cmd}" --format text 2>/dev/null || \
    echo "No help available for '${cmd}'. Run 'canasta --help' for available commands."
}

# --- Argument parsing --------------------------------------------------------

# First pass: extract --verbose/-v and --help/-h from anywhere in args,
# collect remaining args for second pass.
VERBOSE=""
REMAINING=()
HELP_REQUESTED=""

for arg in "$@"; do
    case "$arg" in
        --verbose|-v)
            VERBOSE="true"
            ;;
        --help|-h)
            HELP_REQUESTED="true"
            ;;
        *)
            REMAINING+=("$arg")
            ;;
    esac
done

set -- "${REMAINING[@]+"${REMAINING[@]}"}"

# Handle --help with no command
if [[ -n "$HELP_REQUESTED" && $# -eq 0 ]]; then
    show_help
    exit 0
fi

# No command given
if [[ $# -eq 0 ]]; then
    show_help
    exit 1
fi

# Parse command (and optional subcommand)
COMMAND="$1"
shift

# Commands with subcommands
case "$COMMAND" in
    config|extension|skin|maintenance|devmode|sitemap)
        if [[ $# -eq 0 ]]; then
            echo "Error: '${COMMAND}' requires a subcommand." >&2
            exit 1
        fi
        COMMAND="${COMMAND}_${1}"
        shift
        ;;
    backup)
        if [[ $# -eq 0 ]]; then
            echo "Error: 'backup' requires a subcommand." >&2
            exit 1
        fi
        SUB="$1"
        shift
        if [[ "$SUB" == "schedule" ]]; then
            if [[ $# -eq 0 ]]; then
                echo "Error: 'backup schedule' requires a subcommand." >&2
                exit 1
            fi
            COMMAND="backup_schedule_${1}"
            shift
        else
            COMMAND="backup_${SUB}"
        fi
        ;;
    gitops)
        if [[ $# -eq 0 ]]; then
            echo "Error: 'gitops' requires a subcommand." >&2
            exit 1
        fi
        SUB="$1"
        shift
        # Normalize hyphens to underscores
        SUB="${SUB//-/_}"
        COMMAND="gitops_${SUB}"
        ;;
esac

# Handle --help with a command
if [[ -n "$HELP_REQUESTED" ]]; then
    show_command_help "$COMMAND"
    exit 0
fi

# Parse flags and positional arguments
EXTRA_VARS=()
POSITIONAL_ARGS=""
PARSING_FLAGS=true
while [[ $# -gt 0 ]]; do
    if [[ "$1" == "--" ]]; then
        PARSING_FLAGS=false
        shift
        continue
    fi

    if $PARSING_FLAGS && [[ "$1" == --* ]]; then
        FLAG="${1#--}"
        # Normalize hyphens to underscores
        FLAG="${FLAG//-/_}"
        shift
        # Check if it's a boolean flag (no value follows, or next arg is a flag)
        if [[ $# -eq 0 ]] || [[ "$1" == --* ]] || [[ "$1" == -* && ${#1} -eq 2 ]]; then
            EXTRA_VARS+=(-e "${FLAG}=true")
        else
            EXTRA_VARS+=(-e "${FLAG}=${1}")
            shift
        fi
    elif $PARSING_FLAGS && [[ "$1" == -? ]]; then
        # Short flag
        SHORT="${1#-}"
        shift
        if [[ $# -eq 0 ]] || [[ "$1" == --* ]] || [[ "$1" == -? ]]; then
            # Boolean short flag
            EXTRA_VARS+=(-e "${SHORT}=true")
        else
            EXTRA_VARS+=(-e "${SHORT}=${1}")
            shift
        fi
    else
        # Positional argument (after -- or non-flag)
        if [[ -n "$POSITIONAL_ARGS" ]]; then
            POSITIONAL_ARGS="${POSITIONAL_ARGS} ${1}"
        else
            POSITIONAL_ARGS="$1"
        fi
        shift
    fi
done

# Build ansible-playbook command
ANSIBLE_ARGS=(
    "${ANSIBLE_PLAYBOOK}"
    "${SCRIPT_DIR}/canasta.yml"
    -e "command=${COMMAND}"
)

if [[ -n "$VERBOSE" ]]; then
    # Verbose: use default Ansible callback (shows task names and status)
    # but without -v flag (which dumps full variable contents)
    ANSIBLE_ARGS+=(-e "verbose=true")
else
    # Normal: use minimal callback for clean CLI output
    export ANSIBLE_STDOUT_CALLBACK=canasta_minimal
fi

if [[ ${#EXTRA_VARS[@]} -gt 0 ]]; then
    ANSIBLE_ARGS+=("${EXTRA_VARS[@]}")
fi

if [[ -n "$POSITIONAL_ARGS" ]]; then
    # Map positional args to the appropriate parameter name for the command
    case "$COMMAND" in
        config_get)
            ANSIBLE_ARGS+=(-e "key=${POSITIONAL_ARGS}")
            ;;
        config_set)
            ANSIBLE_ARGS+=(-e "settings=${POSITIONAL_ARGS}")
            ;;
        config_unset)
            ANSIBLE_ARGS+=(-e "keys=${POSITIONAL_ARGS}")
            ;;
        extension_enable|extension_disable)
            ANSIBLE_ARGS+=(-e "extensions=${POSITIONAL_ARGS}")
            ;;
        skin_enable|skin_disable)
            ANSIBLE_ARGS+=(-e "skins=${POSITIONAL_ARGS}")
            ;;
        maintenance_script|maintenance_extension)
            ANSIBLE_ARGS+=(-e "script_args=${POSITIONAL_ARGS}")
            ;;
        maintenance_exec)
            ANSIBLE_ARGS+=(-e "exec_args=${POSITIONAL_ARGS}")
            ;;
        backup_schedule_set)
            ANSIBLE_ARGS+=(-e "cron_expression=${POSITIONAL_ARGS}")
            ;;
        *)
            ANSIBLE_ARGS+=(-e "args=${POSITIONAL_ARGS}")
            ;;
    esac
fi

exec "${ANSIBLE_ARGS[@]}"
