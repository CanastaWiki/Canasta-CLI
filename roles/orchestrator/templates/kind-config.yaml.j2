kind: Cluster
apiVersion: kind.x-k8s.io/v1alpha4
name: {{ _kind_cluster_name }}
nodes:
- role: control-plane
  extraPortMappings:
  - containerPort: 30080
    hostPort: {{ _kind_http_port | default(80) }}
    protocol: TCP
  - containerPort: 30443
    hostPort: {{ _kind_https_port | default(443) }}
    protocol: TCP
