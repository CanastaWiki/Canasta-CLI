# Generated by Canasta-Ansible for instance '{{ id }}'
# Edit this file to customize your Kubernetes deployment.

instance:
  id: {{ id }}

image:
  repository: {{ canasta_image | default(canasta_default_image) | regex_replace(':[^:]+$', '') }}
  tag: "{{ canasta_image | default(canasta_default_image) | regex_replace('^[^:]+:', '') }}"

domains:
  - {{ domain_name | default('localhost') }}

{% set _enable_tls = domain_name | default('localhost') != 'localhost' and not (skip_tls | default(false) | bool) %}
{% if (ingress_class is defined and ingress_class != '') or _enable_tls %}
ingress:
{% if ingress_class is defined and ingress_class != '' %}
  className: {{ ingress_class }}
{% endif %}
{% if _enable_tls %}
  tls: true
  certManager:
    enabled: true
    issuer: letsencrypt-prod
{% endif %}
{% endif %}

secrets:
  dbSecretName: "{{ id }}-db-credentials"
  mwSecretName: "{{ id }}-mw-secrets"

argocd:
  namespace: {{ argocd_namespace | default('argocd') }}
{% if storage_class is defined and storage_class != '' %}

persistence:
  images:
    storageClass: {{ storage_class }}
  extensions:
    storageClass: {{ storage_class }}
  skins:
    storageClass: {{ storage_class }}
  publicAssets:
    storageClass: {{ storage_class }}
{% endif %}
