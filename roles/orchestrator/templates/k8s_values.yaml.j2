# Auto-generated by Canasta for instance '{{ id }}'.
# Manage settings through Canasta commands (e.g. config, upgrade, scale),
# not by editing this file — Canasta rewrites it on those operations and
# does not preserve comments or manual formatting.
{#
  This per-instance Helm values overlay is rendered at create, then
  rewritten in place by Canasta operations (config set, upgrade, scale,
  add, gitops sync, caddy/crowdsec reconcile). Those rewrites round-trip
  the file through YAML parsing, so comments and manual formatting here
  are not preserved. Most settings have a command knob (config / upgrade
  / scale / add); a few create-time fields (ingress class, argocd
  namespace, storage class / access mode, external DB) have none and
  require editing this file or recreating the instance.
#}

instance:
  id: {{ id }}

{# build_from: the image was pushed to the in-cluster registry, so the pod must
   pull the registry-qualified ref ({{ registry }}/{{ _built_image }}); otherwise
   use --canasta-image / the default. Split on the LAST colon so a registry
   address with a port (host:port/repo:tag) parses correctly. #}
{% set _k8s_image = (build_from is defined and build_from != '')
   | ternary((registry | default('10.43.0.2:5000')) ~ '/' ~ (_built_image | default('canasta:local')),
             canasta_image | default(canasta_default_image)) %}
image:
  repository: {{ _k8s_image | regex_replace(':[^:]+$', '') }}
  tag: "{{ _k8s_image | regex_replace('^.*:', '') }}"

domains:
  - {{ domain_name | default('localhost') }}

{% set _enable_tls = domain_name | default('localhost') != 'localhost' and not (skip_tls | default(false) | bool) %}
{% if (ingress_class is defined and ingress_class != '') or _enable_tls %}
ingress:
{% if ingress_class is defined and ingress_class != '' %}
  className: {{ ingress_class }}
{% endif %}
{% if _enable_tls %}
  tls: true
  certManager:
    enabled: true
    issuer: {{ (_staging_certs | default(false)) | ternary('letsencrypt-staging', 'letsencrypt-prod') }}
{% endif %}
{% endif %}

secrets:
  dbSecretName: "{{ id }}-db-credentials"
  mwSecretName: "{{ id }}-mw-secrets"

argocd:
  namespace: {{ argocd_namespace | default('argocd') }}

{% if _use_external_db | default(false) %}
# External database: Canasta points at a DB server the user operates
# (managed service like RDS/Aurora/CloudSQL, or a self-hosted cluster
# such as Galera/MaxScale/Percona XtraDB). The bundled db StatefulSet
# is not deployed when db.enabled is false.
db:
  enabled: false

externalDatabase:
  host: "{{ _external_db_host | default('') }}"
  port: "{{ _external_db_port | default('3306') }}"
  user: "{{ _external_db_user | default('root') }}"
  ssl: "{{ _external_db_ssl | default('false') }}"
{% endif %}
{% if (storage_class is defined and storage_class != '') or (access_mode is defined and access_mode != '') %}

persistence:
  images:
{% if storage_class is defined and storage_class != '' %}
    storageClass: {{ storage_class }}
{% endif %}
{% if access_mode is defined and access_mode != '' %}
    accessMode: {{ access_mode }}
{% endif %}
  extensions:
{% if storage_class is defined and storage_class != '' %}
    storageClass: {{ storage_class }}
{% endif %}
{% if access_mode is defined and access_mode != '' %}
    accessMode: {{ access_mode }}
{% endif %}
  skins:
{% if storage_class is defined and storage_class != '' %}
    storageClass: {{ storage_class }}
{% endif %}
{% if access_mode is defined and access_mode != '' %}
    accessMode: {{ access_mode }}
{% endif %}
  publicAssets:
{% if storage_class is defined and storage_class != '' %}
    storageClass: {{ storage_class }}
{% endif %}
{% if access_mode is defined and access_mode != '' %}
    accessMode: {{ access_mode }}
{% endif %}
{% endif %}
