# To add custom Caddy directives, edit Caddyfile.site instead.
# For global Caddy options or additional site blocks, edit Caddyfile.global instead.

{% if _staging_certs | default(false) %}
# Use the Let's Encrypt staging CA (untrusted by browsers, but
# avoids production rate limits while testing). Toggled by
# CANASTA_STAGING_CERTS in .env.
{
    acme_ca https://acme-staging-v02.api.letsencrypt.org/directory
}

{% endif %}
import /etc/caddy/Caddyfile.global

{{ _site_address }} {
    import /etc/caddy/Caddyfile.site

{% if _observable %}
    @opensearch path /opensearch /opensearch/*
    handle @opensearch {
        basicauth {
            {{ _os_user }} {{ _os_password_hash }}
        }
        reverse_proxy opensearch-dashboards:5601
    }

    handle {
        reverse_proxy {{ _backend }}
    }
{% else %}
    reverse_proxy {{ _backend }}
{% endif %}

    log {
        output file /var/log/caddy/access.log
    }
}
