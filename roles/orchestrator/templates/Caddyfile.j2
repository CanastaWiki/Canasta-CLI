# Auto-generated by Canasta-Ansible — DO NOT EDIT
# To add custom Caddy directives, edit Caddyfile.site instead.
# For global Caddy options or additional site blocks, edit Caddyfile.global instead.

{% if (_staging_certs | default(false)) or (_crowdsec_active | default(false)) or (_trusted_proxies_enabled | default(false)) %}
# Caddy global options block. Caddy permits only one, so every
# CLI-managed global directive is emitted together here.
{
{% if _trusted_proxies_enabled | default(false) %}
    # Recover the real client IP when Caddy is behind a trusted upstream
    # proxy (Cloudflare/Imperva/LB). The trusted source is locked so the
    # client-IP header can't be forged by a client hitting the origin
    # directly. Toggled by CADDY_TRUSTED_PROXIES in .env.
    servers {
        client_ip_headers {{ _trusted_proxies_headers }}
{% if _tp_combine | default(false) %}
        # Kubernetes: Caddy's immediate peer is the in-cluster ingress, not
        # the CDN, so trust the cluster CIDRs AND the CDN's published ranges
        # together via caddy-combine-ip-ranges. caddy-cdn-ranges keeps the
        # provider's edge ranges current in-process (re-fetched on interval).
        trusted_proxies combine {
            static {{ _trusted_proxies_cidrs | join(' ') }}
            cdn_ranges {
                interval 12h
{% if _tp_mode == 'cloudflare' %}
                provider cloudflare
{% elif _tp_mode == 'imperva' %}
                provider {
                    imperva {
                        ipv4_url https://my.imperva.com/api/integration/v1/ips "ipRanges"
                        ipv6_url https://my.imperva.com/api/integration/v1/ips "ipv6Ranges"
                    }
                }
{% endif %}
            }
        }
{% elif _tp_dynamic | default(false) %}
        # caddy-cdn-ranges keeps the provider's edge ranges current
        # in-process (re-fetched on the interval), so this instance never
        # depends on a vendored list or a redeploy to stay correct.
        trusted_proxies cdn_ranges {
            interval 12h
{% if _tp_mode == 'cloudflare' %}
            provider cloudflare
{% elif _tp_mode == 'imperva' %}
            provider {
                imperva {
                    ipv4_url https://my.imperva.com/api/integration/v1/ips "ipRanges"
                    ipv6_url https://my.imperva.com/api/integration/v1/ips "ipv6Ranges"
                }
            }
{% endif %}
        }
{% else %}
        trusted_proxies static {{ _trusted_proxies_cidrs | join(' ') }}
{% if _trusted_proxies_strict | default(false) %}
        trusted_proxies_strict
{% endif %}
{% endif %}
    }
{% endif %}
{% if _staging_certs | default(false) %}
    # Use the Let's Encrypt staging CA (untrusted by browsers, but
    # avoids production rate limits while testing). Toggled by
    # CANASTA_STAGING_CERTS in .env.
    acme_ca https://acme-staging-v02.api.letsencrypt.org/directory
{% endif %}
{% if _crowdsec_active | default(false) %}
    # CrowdSec bouncer. Toggled by CANASTA_ENABLE_CROWDSEC together with
    # a bouncer API key; rewrite_caddy.yml only sets _crowdsec_active
    # when both are present, so the key placeholder below is never empty.
    order crowdsec first
    crowdsec {
        api_url http://crowdsec:8080
        api_key {env.CROWDSEC_BOUNCER_API_KEY}
        # Streaming-mode poll interval. The plugin default is 60s, which
        # leaves up to ~60-90s before a new ban reaches this bouncer; 15s
        # tightens propagation without meaningfully loading the LAPI.
        ticker_interval 15s
    }
{% endif %}
}

{% endif %}
import /etc/caddy/Caddyfile.global

{{ _site_address }} {
    import /etc/caddy/Caddyfile.site

{% if _crowdsec_active | default(false) %}
    crowdsec
{% endif %}
{% if _observable %}
    @opensearch path /opensearch /opensearch/*
    handle @opensearch {
        basicauth {
            {{ _os_user }} {{ _os_password_hash }}
        }
        reverse_proxy opensearch-dashboards:5601
    }

    handle {
        reverse_proxy {{ _backend }}
    }
{% else %}
    reverse_proxy {{ _backend }}
{% endif %}

    log {
        output file /var/log/caddy/access.log
    }
}
